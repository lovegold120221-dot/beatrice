# Gemini API (Required)
GEMINI_API_KEY=your_gemini_api_key_here
NEXT_PUBLIC_GEMINI_API_KEY=your_gemini_api_key_here

# Supabase (Required for auth & chat history)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Ollama (Optional - for local AI inference)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3:latest

# Hugging Face (Optional - for Flux image generation)
HF_TOKEN=your_hf_token_here

# TTS API (Optional - for Coqui XTTS v2, defaults to localhost:8002)
NEXT_PUBLIC_TTS_API_URL=http://localhost:8002

# Gemini Live WebSocket (Defaults to localhost:8001)
NEXT_PUBLIC_GEMINI_LIVE_WS_URL=ws://localhost:8001/ws/audio
